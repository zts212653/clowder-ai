VISION_PROVIDER=

JINA_API_KEY=
SERPER_API_KEY=
PERPLEXITY_API_KEY=
GITHUB_TOKEN=

# Browser MCP runtime (optional)
# 0: disabled, 1: enabled
BROWSER_RUNTIME_MCP_ENABLED=1
# supported here: stdio|sse|streamable-http
# recommended: streamable-http
BROWSER_RUNTIME_MCP_CLIENT_TYPE=streamable-http
BROWSER_RUNTIME_MCP_SERVER_ID=playwright_runtime_wrapper
BROWSER_RUNTIME_MCP_SERVER_NAME=playwright-runtime-wrapper
# when client_type=streamable-http, default endpoint is http://127.0.0.1:8940/mcp
# when client_type=sse, default endpoint is http://127.0.0.1:8940/sse
# when client_type=stdio, this path can keep stdio://... as metadata only
BROWSER_RUNTIME_MCP_SERVER_PATH=http://127.0.0.1:8940/mcp
BROWSER_RUNTIME_MCP_TIMEOUT_S=300
# optional local wrapper host/port/path for auto-start
BROWSER_RUNTIME_MCP_HOST=127.0.0.1
BROWSER_RUNTIME_MCP_PORT=8940
BROWSER_RUNTIME_MCP_PATH=/mcp
# stdio mode command override (empty means use current python executable)
BROWSER_RUNTIME_MCP_COMMAND=
# optional args override; leave empty to use built-in default:
# <repo>/jiuwenclaw/agentserver/tools/browser-move/src/playwright_runtime_mcp_server.py --transport stdio --no-banner
BROWSER_RUNTIME_MCP_ARGS=
# stdio mode will prefer sse fallback first when enabled (recommended 1)
BROWSER_RUNTIME_MCP_AUTO_SSE_FALLBACK=1

# runtime wrapper internals
PLAYWRIGHT_MCP_COMMAND=npx
PLAYWRIGHT_MCP_ARGS=-y @playwright/mcp@latest
PLAYWRIGHT_CDP_URL=http://127.0.0.1:9222
PLAYWRIGHT_TOOL_TIMEOUT_S=300
BROWSER_TIMEOUT_S=300
# default behavior: browser_run_task will not honor model-provided timeout_s values below
# BROWSER_TIMEOUT_S. Set this only if you explicitly want short per-call overrides.
BROWSER_ALLOW_SHORT_TIMEOUT_OVERRIDE=0

######## BROWSER MOVE MODE ########
# managed browser
BROWSER_DRIVER=managed
BROWSER_PROFILE_NAME=Default

# # remote browser 
# BROWSER_DRIVER=remote
# PLAYWRIGHT_CDP_URL=http://127.0.0.1:9222

# # playwright extension browser 
# BROWSER_DRIVER=extension
# PLAYWRIGHT_MCP_EXTENSION_TOKEN=

EMAIL_ADDRESS=""
EMAIL_TOKEN=""

EVOLUTION_AUTO_SCAN="false"

# SkillNet timeout configuration
SKILLNET_DOWNLOAD_TIMEOUT=60
SKILLNET_MAX_RETRIES=3

NO_PROXY=localhost,127.0.0.1,api.openai.rnd.huawei.com