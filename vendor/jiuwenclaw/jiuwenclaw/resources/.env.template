API_BASE="https://example.com/compatible-mode/v1"
API_KEY="sk-xxxxxxxxx"
MODEL_NAME="your-model-name"
# or other provider like SiliconFlow, etc.
MODEL_PROVIDER=OpenAI
DEFAULT_HEADERS=

EMBED_API_BASE=
EMBED_API_KEY=
EMBED_MODEL=

# Video processing model configuration.
VIDEO_API_BASE=
VIDEO_API_KEY=
VIDEO_MODEL_NAME="your-video-model-name"
VIDEO_PROVIDER=

# Audio processing model selection.
AUDIO_API_BASE=
AUDIO_API_KEY=
AUDIO_MODEL_NAME="your-audio-model-name"
AUDIO_PROVIDER=

# Vision/Image processing model selection.
VISION_API_BASE=
