# openJiuwen-DeepSearch 环境配置文件
# 复制此文件为 .env 并填入你的 API Key

# ============================================================================
# LLM 配置（必需）
# ============================================================================

# OpenAI（推荐）
LLM_MODEL_NAME=gpt-4o
LLM_MODEL_TYPE=openai
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your_openai_api_key_here

# SiliconFlow（备选，成本更低）
# 取消注释以下行以使用 SiliconFlow
# LLM_MODEL_NAME=Qwen/Qwen2.5-72B-Instruct
# LLM_MODEL_TYPE=siliconflow
# LLM_BASE_URL=https://api.siliconflow.cn/v1
# LLM_API_KEY=your_siliconflow_api_key_here

# ============================================================================
# 搜索引擎配置（必需）
# ============================================================================

# Tavily（推荐，获取简单）
# 获取 API Key: https://tavily.com/
WEB_SEARCH_ENGINE_NAME=tavily
WEB_SEARCH_API_KEY=your_tavily_api_key_here
WEB_SEARCH_URL=https://api.tavily.com

# Google（备选）
# 取消注释以下行以使用 Google Custom Search
# 需要先创建 Google Custom Search Engine
# 获取 API Key: https://developers.google.com/custom-search/v1/overview
# WEB_SEARCH_ENGINE_NAME=google
# WEB_SEARCH_API_KEY=your_google_api_key_here
# WEB_SEARCH_URL=https://www.googleapis.com/customsearch/v1

# ============================================================================
# 其他配置（可选）
# ============================================================================

# 单次搜索最大返回结果数（默认: 5）
MAX_WEB_SEARCH_RESULTS=5

# workflow 执行方式（默认: parallel）
# - parallel: 并行执行（推荐）
# - dependency_driving: 依赖驱动执行
EXECUTION_METHOD=parallel
