#!/bin/bash
# Pre-commit hook: prevent accidental commits on runtime/* branches
# Install: git config core.hooksPath scripts/hooks
# Or:      cp scripts/hooks/pre-commit .git/hooks/pre-commit

set -euo pipefail

BRANCH="$(git symbolic-ref --short HEAD 2>/dev/null || true)"

if [[ "$BRANCH" == runtime/* ]]; then
  cat >&2 <<EOF

╔══════════════════════════════════════════════════════════════╗
║  🚫 COMMIT BLOCKED: runtime branch protection               ║
╠══════════════════════════════════════════════════════════════╣
║                                                              ║
║  You are on branch: $BRANCH
║                                                              ║
║  runtime/* branches are production branches that track       ║
║  origin/main. Committing directly to them will cause the     ║
║  runtime to diverge and break on next sync.                  ║
║                                                              ║
║  Instead:                                                    ║
║    1. Create a feature branch:                               ║
║       git checkout -b feat/my-feature origin/main            ║
║    2. Make your changes there                                ║
║    3. Submit a PR to main                                    ║
║                                                              ║
║  To bypass (emergency only):                                 ║
║    git commit --no-verify                                    ║
║                                                              ║
╚══════════════════════════════════════════════════════════════╝

EOF
  exit 1
fi
