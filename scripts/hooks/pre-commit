#!/bin/bash
# Pre-commit hook: prevent accidental commits on protected branches
# Install: git config core.hooksPath scripts/hooks
# Or:      cp scripts/hooks/pre-commit .git/hooks/pre-commit

set -euo pipefail

BRANCH="$(git symbolic-ref --short HEAD 2>/dev/null || true)"

BLOCKED=false
REASON=""

if [[ "$BRANCH" == "main" ]]; then
  BLOCKED=true
  REASON="main is the primary branch. All changes must go through PRs."
elif [[ "$BRANCH" == runtime/* ]]; then
  BLOCKED=true
  REASON="runtime/* branches track origin/main for production. Committing directly will cause divergence and break on next sync."
fi

if [[ "$BLOCKED" == true ]]; then
  cat >&2 <<EOF

╔══════════════════════════════════════════════════════════════╗
║  COMMIT BLOCKED: protected branch                            ║
╠══════════════════════════════════════════════════════════════╣
║                                                              ║
║  Branch: $BRANCH
║  Reason: $REASON
║                                                              ║
║  Instead:                                                    ║
║    1. Create a feature branch:                               ║
║       git checkout -b feat/my-feature origin/main            ║
║    2. Make your changes there                                ║
║    3. Submit a PR to main                                    ║
║                                                              ║
║  To bypass (emergency only):                                 ║
║    git commit --no-verify                                    ║
║                                                              ║
╚══════════════════════════════════════════════════════════════╝

EOF
  exit 1
fi
